---
const benefits = [
  {
    icon: "💖",
    title: "Regalos que emocionan",
    desc: "Mensajes y presentaciones pensadas para convertir el regalo en una experiencia afectiva única."
  },
  {
    icon: "🍫",
    title: "Chocolate premium",
    desc: "Una percepción superior desde el primer vistazo: brillo, textura gourmet, empaque de lujo y sabor sublime."
  },
  {
    icon: "🎀",
    title: "Presentaciones elegantes",
    desc: "Diseño visual limpio, sofisticado y memorable para diferenciarse por completo de un regalo común."
  },
  {
    icon: "✨",
    title: "Momentos inolvidables",
    desc: "No es solo la compra: es el instante en el que mamá siente que pensaron en ella con cariño y distinción."
  }
];
---

<section id="porque" class="relative py-24 px-6 bg-gradient-to-b from-warm-white to-soft-pink/50 overflow-hidden">
  <!-- Soft background glow -->
  <div class="absolute w-[400px] h-[400px] -left-20 top-10 rounded-full bg-radial from-gold-premium/8 to-transparent filter blur-xl pointer-events-none" aria-hidden="true"></div>
  
  <div class="max-w-6xl mx-auto relative z-10">
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="inline-flex items-center justify-center gap-2 mb-4 text-rose-wine uppercase tracking-[0.16em] font-bold text-xs">
        <span class="w-2 h-2 rounded-full bg-rose-wine animate-pulse"></span>
        Más que chocolate
      </span>
      <h2 class="font-serif text-4xl md:text-5xl font-extrabold tracking-tight text-berry-dark leading-tight">
        Un detalle que emociona antes de abrirse
      </h2>
      <p class="text-sm md:text-base leading-relaxed text-dark-chocolate/75 mt-5">
        No entregamos una caja cualquiera: entregamos el instante en que mamá siente que pensaron en ella con cariño, elegancia y buen gusto.
      </p>
    </div>

    <!-- Benefits Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {benefits.map((b) => (
        <article class="relative p-7 rounded-[30px] border border-rose-wine/10 bg-warm-white/70 backdrop-blur-md shadow-card hover:shadow-hover hover:-translate-y-1.5 transition-all duration-300 group">
          <!-- Glass sheen overlay -->
          <div class="absolute inset-0 rounded-[30px] bg-gradient-to-br from-white/20 to-transparent pointer-events-none" aria-hidden="true"></div>
          
          <!-- Icon wrap -->
          <div class="w-12 h-12 rounded-full bg-gradient-to-br from-gold-premium to-champagne-gold shadow-[0_10px_25px_rgba(212,175,55,0.22)] flex items-center justify-center text-xl mb-5 group-hover:scale-110 transition-transform duration-300">
            {b.icon}
          </div>
          
          <h3 class="font-serif font-bold text-lg text-berry-dark tracking-tight leading-snug">
            {b.title}
          </h3>
          <p class="text-xs md:text-sm text-dark-chocolate/72 leading-relaxed mt-3">
            {b.desc}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
