---
---
<section class="relative py-28 px-6 bg-gradient-to-br from-berry-dark via-[#2A0A1D] to-dark-chocolate text-warm-white overflow-hidden">
  <!-- Glowing luxury backdrops -->
  <div class="absolute w-[450px] h-[450px] left-[-150px] top-[-50px] rounded-full bg-radial from-gold-premium/12 to-transparent filter blur-2xl pointer-events-none" aria-hidden="true"></div>
  <div class="absolute w-[500px] h-[500px] right-[-150px] bottom-[-100px] rounded-full bg-radial from-satin-pink/15 to-transparent filter blur-2xl pointer-events-none" aria-hidden="true"></div>
  
  <!-- Subtle Bokeh Lights inside Section -->
  <div class="absolute inset-0 pointer-events-none opacity-40 z-0">
    <div class="absolute w-8 h-8 rounded-full bg-gold-premium/30 filter blur-sm left-[15%] top-[25%] animate-pulse"></div>
    <div class="absolute w-12 h-12 rounded-full bg-soft-pink/20 filter blur-md right-[20%] top-[15%] animate-pulse" style="animation-delay: 2s;"></div>
    <div class="absolute w-6 h-6 rounded-full bg-gold-premium/25 filter blur-xs left-[35%] bottom-[20%] animate-pulse" style="animation-delay: 1.5s;"></div>
    <div class="absolute w-10 h-10 rounded-full bg-satin-pink/30 filter blur-sm right-[10%] bottom-[30%] animate-pulse" style="animation-delay: 3s;"></div>
  </div>

  <div class="max-w-4xl mx-auto relative z-10 text-center">
    <!-- Quote Card -->
    <div class="border border-gold-premium/20 rounded-[38px] px-8 py-16 md:p-20 bg-gradient-to-br from-warm-white/12 to-warm-white/4 backdrop-blur-xl shadow-[0_30px_90px_rgba(0,0,0,0.22)]">
      
      <p class="font-serif text-3xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight text-warm-white mb-8 drop-shadow-[0_8px_24px_rgba(42,22,18,0.4)]">
        “Hay personas que merecen más que palabras.”
      </p>
      
      <span class="font-serif text-lg md:text-2xl text-champagne-gold/90 font-medium italic block tracking-wide">
        Este Día de la Madre… regálale un recuerdo.
      </span>
      
    </div>
  </div>
</section>
