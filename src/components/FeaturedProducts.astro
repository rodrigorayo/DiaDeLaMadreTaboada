---
import { Image } from 'astro:assets';
import cajaCorazones from '../assets/caja_corazones.png';
import cajaSurtida from '../assets/caja_surtida.png';
import detallePremium from '../assets/detalle_premium.png';

const products = [
  {
    image: cajaCorazones,
    title: "Caja Rosada Corazones",
    tagline: "Eres una mamá increíble",
    description: "Más que chocolate… una forma elegante de decir gracias por todo.",
    bgClass: "from-[#F6D5E5] via-[#C75C91] to-[#7A1E4D]",
    whatsappMsg: "Hola,%20quiero%20sorprender%20a%20mam%C3%A1%20con%20la%20Caja%20Rosada%20Corazones",
    weight: "180 g"
  },
  {
    image: cajaSurtida,
    title: "Caja Surtida Rellenos",
    tagline: "Un recuerdo inolvidable",
    description: "Una selección especial de bombones finos para sorprender con sabor, presentación y emoción.",
    bgClass: "from-[#FFF2C5] via-[#D4AF37] to-[#7A4F10]",
    whatsappMsg: "Hola,%20quiero%20sorprender%20a%20mam%C3%A1%20con%20la%20Caja%20Surtida%20Rellenos",
    weight: "122 g"
  },
  {
    image: detallePremium,
    title: "Detalle Premium",
    tagline: "Elegancia para sorprender",
    description: "El regalo gourmet ideal cuando quieres resolver rápido, pero sin perder la alta categoría.",
    bgClass: "from-[#7A1E4D] via-[#4B0F2F] to-[#2A1612]",
    whatsappMsg: "Hola,%20quiero%20un%20detalle%20premium%20para%20mam%C3%A1",
    weight: "Gourmet Edition"
  }
];

const phoneNumber = "59167998576";
---

<section id="productos" class="relative py-24 px-6 bg-gradient-to-b from-soft-pink/30 to-[#F9E7EF] overflow-hidden">
  <!-- Glowing elements -->
  <div class="absolute w-[500px] h-[500px] right-[-100px] top-[20%] rounded-full bg-radial from-satin-pink/10 to-transparent filter blur-2xl pointer-events-none" aria-hidden="true"></div>
  
  <div class="max-w-6xl mx-auto relative z-10">
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="inline-flex items-center justify-center gap-2 mb-4 text-rose-wine uppercase tracking-[0.16em] font-bold text-xs">
        <span class="w-2 h-2 rounded-full bg-rose-wine"></span>
        Regalos destacados
      </span>
      <h2 class="font-serif text-4xl md:text-5xl font-extrabold tracking-tight text-berry-dark leading-tight">
        Elige el detalle perfecto para mamá
      </h2>
      <p class="text-sm md:text-base leading-relaxed text-dark-chocolate/75 mt-5">
        Diseños con máximo impacto visual, pocos productos y mucho aire premium. La decisión de regalar debe sentirse fácil, elegante y llena de emoción.
      </p>
    </div>

    <!-- Products Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {products.map((p) => (
        <article class="p-5 rounded-[38px] border border-rose-wine/10 bg-warm-white/70 backdrop-blur-md shadow-card hover:shadow-hover hover:-translate-y-2 transition-all duration-300 flex flex-col justify-between group">
          <div>
            <!-- Image Wrap -->
            <div class={`h-[260px] rounded-[26px] mb-6 flex items-center justify-center relative overflow-hidden bg-gradient-to-br ${p.bgClass} shadow-[inset_0_1px_0_rgba(255,255,255,0.4),_0_15px_35px_rgba(122,30,77,0.14)]`}>
              <!-- Inner Radial Highlight -->
              <div class="absolute w-44 h-44 rounded-full bg-radial from-white/30 to-transparent filter blur-sm pointer-events-none" aria-hidden="true"></div>
              
              <!-- Image element -->
              <Image 
                src={p.image} 
                alt={p.title} 
                class="max-h-[190px] object-contain relative z-10 drop-shadow-[0_15px_25px_rgba(42,22,18,0.35)] group-hover:scale-105 transition-transform duration-500" 
              />
              
              <!-- Product Weight / Tag -->
              <span class="absolute bottom-4 right-4 bg-dark-chocolate/40 backdrop-blur-md border border-white/20 text-[10px] text-warm-white tracking-widest uppercase font-bold py-1 px-3 rounded-full z-20">
                {p.weight}
              </span>
            </div>

            <!-- Title & Slogan -->
            <h3 class="font-serif font-extrabold text-2xl text-berry-dark leading-tight group-hover:text-rose-wine transition-colors duration-300">
              {p.title}
            </h3>
            
            <span class="block text-xs font-semibold text-rose-wine tracking-wider uppercase mt-2 italic">
              “{p.tagline}”
            </span>
            
            <!-- Description -->
            <p class="text-xs md:text-sm text-dark-chocolate/70 leading-relaxed mt-3">
              {p.description}
            </p>
          </div>

          <!-- Purchase CTA -->
          <div class="mt-8 pt-5 border-t border-rose-wine/5">
            <a 
              href={`https://wa.me/${phoneNumber}?text=${p.whatsappMsg}`} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="inline-flex items-center gap-2 font-extrabold text-sm text-rose-wine hover:text-berry-dark transition-colors duration-300 group/link"
            >
              Quiero este detalle 
              <span class="group-hover/link:translate-x-1.5 transition-transform duration-300">→</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
