---
// Floating gold particles component
const particles = Array.from({ length: 15 }, (_, i) => ({
  id: i,
  top: `${Math.random() * 100}%`,
  left: `${Math.random() * 100}%`,
  delay: `${Math.random() * 8}s`,
  size: `${Math.random() * 5 + 3}px`,
  duration: `${Math.random() * 8 + 8}s`,
}));
---

<div class="absolute inset-0 overflow-hidden pointer-events-none z-0 opacity-80" aria-hidden="true">
  {particles.map((p) => (
    <span
      class="absolute rounded-full bg-gold-premium/60 shadow-[0_0_15px_rgba(212,175,55,0.8)] animate-float-particle"
      style={{
        top: p.top,
        left: p.left,
        width: p.size,
        height: p.size,
        animationDelay: p.delay,
        animationDuration: p.duration,
      }}
    />
  ))}
</div>
